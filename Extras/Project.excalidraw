    },
    {
      "id": "8wI8rFLIHQE-6cwJWq2PI",
      "type": "text",
      "x": 906.0195542877229,
      "y": -349.54575849617595,
      "width": 1046.110805246502,
      "height": 816.5496051632849,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#1971c2",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ac",
      "roundness": null,
      "seed": 486438264,
      "version": 1668,
      "versionNonce": 2068112136,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763916129264,
      "link": null,
      "locked": false,
      "text": "START\n  ↓\nInitialize Database\n  ↓\nMain Menu (4 options)\n  ├─→ 1. Customer Login/Register\n  │      ├─→ Register → Enter details → Success\n  │      └─→ Login → Email/Password → Customer Dashboard\n  │            ├─→ Browse & Order → Select Restaurant → Select Items → Confirm\n  │            │                     → Order placed → Thread starts processing\n  │            ├─→ View Orders → List all orders with status\n  │            ├─→ View Profile → Display customer info\n  │            └─→ Back\n  │\n  ├─→ 2. Restaurant Login/Register\n  │      ├─→ Register → Enter details → Success\n  │      └─→ Login → Email/Password → Restaurant Dashboard\n  │            ├─→ Add Menu Item → Enter details → Saved to DB\n  │            ├─→ View Menu → Display all items\n  │            ├─→ View Orders → List orders for this restaurant\n  │            ├─→ Update Order Status → Manual status change\n  │            ├─→ Generate Sales Report → Create file in reports/\n  │            └─→ Back\n  │\n  ├─→ 3. Browse Restaurants → Display all (no login needed)\n  │\n  └─→ 4. Exit → END",
      "fontSize": 24.194062375208443,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "START\n  ↓\nInitialize Database\n  ↓\nMain Menu (4 options)\n  ├─→ 1. Customer Login/Register\n  │      ├─→ Register → Enter details → Success\n  │      └─→ Login → Email/Password → Customer Dashboard\n  │            ├─→ Browse & Order → Select Restaurant → Select Items → Confirm\n  │            │                     → Order placed → Thread starts processing\n  │            ├─→ View Orders → List all orders with status\n  │            ├─→ View Profile → Display customer info\n  │            └─→ Back\n  │\n  ├─→ 2. Restaurant Login/Register\n  │      ├─→ Register → Enter details → Success\n  │      └─→ Login → Email/Password → Restaurant Dashboard\n  │            ├─→ Add Menu Item → Enter details → Saved to DB\n  │            ├─→ View Menu → Display all items\n  │            ├─→ View Orders → List orders for this restaurant\n  │            ├─→ Update Order Status → Manual status change\n  │            ├─→ Generate Sales Report → Create file in reports/\n  │            └─→ Back\n  │\n  ├─→ 3. Browse Restaurants → Display all (no login needed)\n  │\n  └─→ 4. Exit → END",
      "autoResize": false,
      "lineHeight": 1.25
    },
